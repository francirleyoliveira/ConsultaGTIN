# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
.venv/
env/

# Variaveis de ambiente (contem senhas e certificados)
.env

# IDEs e editores
.vscode/
.idea/
*.swp
*.swo

# Arquivos do sistema operacional
Thumbs.db
Desktop.ini
.DS_Store

# Distribuicao / empacotamento
dist/
build/
*.egg-info/
*.egg

# Logs
*.log

# Dados locais
/data/*.db

# Saidas geradas
output/relatorios/*.xlsx
output/diagnosticos/*.xml
output/diagnosticos/*.txt

# Arquivos temporarios
*.tmp
*.bak
*.old

# Certificados digitais
*.pfx
*.p12
*.pem
*.key
